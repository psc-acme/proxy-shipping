{
    "name": "psc-acme/proxy-shipping",
    "description": "Package proxy-shipping for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProxyShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/console": "^7.0",
        "nesbot/carbon": "^2.72",
        "psc-acme/helper-catalog": "^1.0",
        "psc-acme/driver-product": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "infection/infection": "^0.27",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}